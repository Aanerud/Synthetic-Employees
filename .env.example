# MCP Server Configuration
MCP_SERVER_URL=https://mcp.nstop.no

# Work Hours Configuration (local time, 24-hour format)
WORK_START_HOUR=9
WORK_END_HOUR=17
TIMEZONE=America/Los_Angeles

# Agent Tick Configuration
TICK_INTERVAL_MINUTES=5
RANDOMIZE_TICKS=true

# LLM Configuration (optional, for advanced behaviors)
# Get API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
LLM_MODEL=claude-3-5-sonnet-20241022

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/agents.log
LOG_FORMAT=json

# Database
DATABASE_PATH=data/agent_state.db

# Simulation Settings
TIME_ACCELERATION=1.0
ENABLE_WEEKENDS=false

# Optional: Specific role tick frequencies (overrides TICK_INTERVAL_MINUTES)
# Format: ROLE_TICK_MINUTES_<ROLE>=<minutes>
# ROLE_TICK_MINUTES_CEO=30
# ROLE_TICK_MINUTES_DEVELOPER=60
# ROLE_TICK_MINUTES_PM=45
