# Azure AD (required for M365 authentication)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
DEFAULT_PASSWORD=password-for-synthetic-users

# MCP Server (local instance of MCP-Microsoft-Office)
MCP_SERVER_URL=http://localhost:3000
MCP_ADAPTER_PATH=/path/to/MCP-Microsoft-Office/mcp-adapter.cjs

# All other settings are in config.yaml
